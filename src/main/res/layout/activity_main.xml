<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/dark_gray"
        android:padding="10dp">

        <TextView
            android:id="@+id/compassStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pusula: hazir"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/azimutuResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Mod: Kuzey (Polaris + desen eslestirme)"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/latitudeResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tahmini enlem burada"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <LinearLayout
            android:id="@+id/galleryDatePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/manualDateCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Galeri tarihi"
                android:textColor="@color/light_gray"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/manualDateInput"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="YYYY-MM-DD"
                android:inputType="date"
                android:maxLines="1"
                android:textColor="@color/light_gray"
                android:textColorHint="@color/light_gray"
                android:textSize="11sp"
                android:enabled="false"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/captureButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="CEK"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="13sp" />

            <Button
                android:id="@+id/galleryButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="GALERI"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="13sp" />

            <Button
                android:id="@+id/modeButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="MOD: KUZEY"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
