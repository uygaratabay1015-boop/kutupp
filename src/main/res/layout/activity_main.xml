<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/dark_gray"
        android:padding="10dp">

        <TextView
            android:id="@+id/compassStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pusula: hazir"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/azimutuResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Foto sec veya cek, sonra HESAPLA"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/latitudeResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tahmini enlem burada"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <LinearLayout
            android:id="@+id/galleryDatePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical">

            <RadioGroup
                android:id="@+id/dateModeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/dateModeToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bugun"
                    android:textColor="@color/light_gray"
                    android:textSize="11sp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/dateModeManual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Elle tarih+saat"
                    android:textColor="@color/light_gray"
                    android:textSize="11sp" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/manualDateInput"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="YYYY-MM-DD"
                    android:inputType="date"
                    android:maxLines="1"
                    android:textColor="@color/light_gray"
                    android:textColorHint="@color/light_gray"
                    android:textSize="11sp"
                    android:enabled="false"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/manualTimeInput"
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:hint="HH:mm"
                    android:inputType="time"
                    android:maxLines="1"
                    android:textColor="@color/light_gray"
                    android:textColorHint="@color/light_gray"
                    android:textSize="11sp"
                    android:enabled="false"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/calibrationPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kalibrasyon (Galeri icin onerilir)"
                android:textColor="@color/light_gray"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/manualPitchInput"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Pitch (derece)"
                    android:inputType="numberDecimal|numberSigned"
                    android:maxLines="1"
                    android:textColor="@color/light_gray"
                    android:textColorHint="@color/light_gray"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/manualAzimuthInput"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:hint="Yon/Azimut 0-360"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:textColor="@color/light_gray"
                    android:textColorHint="@color/light_gray"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <EditText
                android:id="@+id/manualHorizonPercentInput"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:hint="Ufuk Yuzdesi (0-100, opsiyonel)"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:textColor="@color/light_gray"
                android:textColorHint="@color/light_gray"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <EditText
                android:id="@+id/manualRollInput"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:hint="Roll (derece, opsiyonel)"
                android:inputType="numberDecimal|numberSigned"
                android:maxLines="1"
                android:textColor="@color/light_gray"
                android:textColorHint="@color/light_gray"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/horizonPickButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:text="UFUK SEC (FOTOGRAFTA)"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="11sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/offlinePlateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Offline plate solve (katalog)"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/captureButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="CEK"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="13sp" />

            <Button
                android:id="@+id/galleryButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="GALERI"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="13sp" />

            <Button
                android:id="@+id/calculateButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="HESAPLA"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/modeButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:text="MOD: KUZEY"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/showMapButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="HARITA"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
